  folder: 'GEE_exports',
  fileNamePrefix: 'Deforestation_2005_2024_Rondonia',
  region: studyArea,
  scale: 30,
  maxPixels: 1e13
});
// ==========================
// Forest loss and gain from class change only
// ==========================
var deforestation = forest2005.eq(1)
  .and(forest2024.eq(0))
  .rename('loss');

var forestGain = forest2005.eq(0)
  .and(forest2024.eq(1))
  .rename('gain');

Map.addLayer(deforestation.selfMask(), {palette: ['red']}, 'Forest Loss 2005-2024');
Map.addLayer(forestGain.selfMask(), {palette: ['blue']}, 'Forest Gain 2005-2024');

// Areas
var lossArea = deforestation
  .multiply(pixelAreaKm2)
  .reduceRegion({
    reducer: ee.Reducer.sum(),
    geometry: studyArea,
    scale: 30,
    maxPixels: 1e13,
    bestEffort: true,
    tileScale: 4
  });

var gainArea = forestGain
  .multiply(pixelAreaKm2)
  .reduceRegion({
    reducer: ee.Reducer.sum(),
    geometry: studyArea,
    scale: 30,
    maxPixels: 1e13,
    bestEffort: true,
    tileScale: 4
  });

print('Forest loss area 2005-2024 (km2):', lossArea.get('loss'));
print('Forest gain area 2005-2024 (km2):', gainArea.get('gain'));

var netChange = ee.Number(gainArea.get('gain')).subtract(ee.Number(lossArea.get('loss')));
print('Net forest change from gain-loss (km2):', netChange);



