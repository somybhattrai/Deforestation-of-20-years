// ==========================
// STEP 1: Study area
// ==========================
var studyArea = ee.Geometry.Rectangle([
  -63.10, -11.30,
  -62.20, -10.60
]);

Map.centerObject(studyArea, 9);
Map.addLayer(studyArea, {color: 'red'}, 'Study Area');

// ==========================
// STEP 2: Common functions
// ==========================
function applyScaleFactors(image) {
  var opticalBands = image.select('SR_B.*').multiply(0.0000275).add(-0.2);
  return image.addBands(opticalBands, null, true);
}

function maskLandsat(image) {
  var qa = image.select('QA_PIXEL');
  var mask = qa.bitwiseAnd(1 << 0).eq(0)
    .and(qa.bitwiseAnd(1 << 1).eq(0))
    .and(qa.bitwiseAnd(1 << 2).eq(0))
    .and(qa.bitwiseAnd(1 << 3).eq(0))
    .and(qa.bitwiseAnd(1 << 4).eq(0))
    .and(qa.bitwiseAnd(1 << 5).eq(0));
  return image.updateMask(mask);
}

// ==========================
// STEP 3: 2005 composite and NDVI
// ==========================
var collection2005 = ee.ImageCollection('LANDSAT/LT05/C02/T1_L2')
  .filterBounds(studyArea)
  .filterDate('2005-05-01', '2005-10-31');

var image2005 = collection2005
  .map(applyScaleFactors)
  .map(maskLandsat)
  .median()
  .clip(studyArea);

Map.addLayer(
  image2005.select(['SR_B3', 'SR_B2', 'SR_B1']),
  {min: 0.03, max: 0.30},
  'RGB 2005'
);

var ndvi2005 = image2005.normalizedDifference(['SR_B4', 'SR_B3']).rename('NDVI');

Map.addLayer(
  ndvi2005,
  {min: 0, max: 1, palette: ['white', 'yellow', 'green']},
  'NDVI 2005'
);

print('2005 bands:', image2005.bandNames());
print('2005 NDVI ready');

// ==========================
// STEP 4: Forest mask for 2005
// ==========================
var forestThreshold = 0.65;

// Keep as binary 0/1 for calculations
var forest2005 = ndvi2005.gte(forestThreshold).rename('forest');

// Display version only
var forest2005Display = forest2005.selfMask();

Map.addLayer(
  forest2005Display,
  {palette: ['006400']},
  'Forest 2005'
);

// ==========================
// STEP 5: 2024 composite and forest
// ==========================
var collection2024 = ee.ImageCollection('LANDSAT/LC08/C02/T1_L2')
  .merge(ee.ImageCollection('LANDSAT/LC09/C02/T1_L2'))
  .filterBounds(studyArea)
  .filterDate('2024-05-01', '2024-10-31');

var image2024 = collection2024
  .map(applyScaleFactors)
  .map(maskLandsat)
  .median()
  .clip(studyArea);

Map.addLayer(
  image2024.select(['SR_B4', 'SR_B3', 'SR_B2']),
  {min: 0.03, max: 0.30},
  'RGB 2024'
);

var ndvi2024 = image2024.normalizedDifference(['SR_B5', 'SR_B4']).rename('NDVI');

Map.addLayer(
  ndvi2024,
  {min: 0, max: 1, palette: ['white', 'yellow', 'green']},
  'NDVI 2024'
);

// Keep as binary 0/1 for calculations
var forest2024 = ndvi2024.gte(forestThreshold).rename('forest');

// Display version only
var forest2024Display = forest2024.selfMask();

Map.addLayer(
  forest2024Display,
  {palette: ['00AA00']},
  'Forest 2024'
);

print('2024 bands:', image2024.bandNames());
print('2024 NDVI ready');

// ==========================
// STEP 6: Deforestation map (2005 vs 2024)
// ==========================
var ndviDrop = ndvi2005.subtract(ndvi2024);
var lossDropThreshold = 0.15;

// Forest in 2005, not forest in 2024, and NDVI decreased enough
var deforestation = forest2005
  .and(forest2024.eq(0))
  .and(ndviDrop.gte(lossDropThreshold))
  .rename('loss');

// Display version only
var deforestationDisplay = deforestation.selfMask();

Map.addLayer(
  deforestationDisplay,
  {palette: ['red']},
  'Deforestation 2005-2024'
);

// ==========================
// STEP 7: Area calculation
// ==========================
var pixelAreaKm2 = ee.Image.pixelArea().divide(1e6);

// Forest area 2005
var forestArea2005 = forest2005
  .multiply(pixelAreaKm2)
  .reduceRegion({
    reducer: ee.Reducer.sum(),
    geometry: studyArea,
    scale: 30,
    maxPixels: 1e13,
    bestEffort: true,
    tileScale: 4
  });

// Forest area 2024
var forestArea2024 = forest2024
  .multiply(pixelAreaKm2)
  .reduceRegion({
    reducer: ee.Reducer.sum(),
    geometry: studyArea,
    scale: 30,
    maxPixels: 1e13,
    bestEffort: true,
    tileScale: 4
  });

// Deforestation area
var deforestationArea = deforestation
  .multiply(pixelAreaKm2)
  .reduceRegion({
    reducer: ee.Reducer.sum(),
    geometry: studyArea,
    scale: 30,
    maxPixels: 1e13,
    bestEffort: true,
    tileScale: 4
  });

// Print clean numeric outputs
print('Forest area 2005 (km2):', forestArea2005.get('forest'));
print('Forest area 2024 (km2):', forestArea2024.get('forest'));
print('Total deforestation area 2005-2024 (km2):', deforestationArea.get('loss'));

// Optional check
var area2005 = ee.Number(forestArea2005.get('forest'));
var area2024 = ee.Number(forestArea2024.get('forest'));
print('Forest area difference 2005-2024 (km2):', area2005.subtract(area2024));

// ==========================
// STEP 8: Export deforestation map
// ==========================
Export.image.toDrive({
