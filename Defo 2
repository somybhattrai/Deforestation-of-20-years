// ==========================
// 2. COMMON FUNCTIONS
// ==========================
function applyScaleFactors(image) {
  var opticalBands = image.select('SR_B.*').multiply(0.0000275).add(-0.2);
  return image.addBands(opticalBands, null, true);
}

function maskLandsat(image) {
  var qa = image.select('QA_PIXEL');
  var mask = qa.bitwiseAnd(1 << 0).eq(0)
    .and(qa.bitwiseAnd(1 << 1).eq(0))
    .and(qa.bitwiseAnd(1 << 2).eq(0))
    .and(qa.bitwiseAnd(1 << 3).eq(0))
    .and(qa.bitwiseAnd(1 << 4).eq(0))
    .and(qa.bitwiseAnd(1 << 5).eq(0));
  return image.updateMask(mask);
}

// ==========================
// 3. SETTINGS
// ==========================
var forestThreshold = 0.60;   // Recommended threshold
var years = ee.List.sequence(2005, 2024);

// ==========================
// 4. FUNCTION: GET YEARLY NDVI + FOREST
// ==========================
function getAnnualProducts(year) {
  year = ee.Number(year);

  var start = ee.Date.fromYMD(year, 5, 1);
  var end = ee.Date.fromYMD(year, 10, 31);

  var collection = ee.ImageCollection(
    ee.Algorithms.If(
      year.lte(2011),
      ee.ImageCollection('LANDSAT/LT05/C02/T1_L2'),
      ee.Algorithms.If(
        year.eq(2012),
        ee.ImageCollection('LANDSAT/LE07/C02/T1_L2'),
        ee.Algorithms.If(
          year.lte(2021),
          ee.ImageCollection('LANDSAT/LC08/C02/T1_L2'),
          ee.ImageCollection('LANDSAT/LC08/C02/T1_L2')
            .merge(ee.ImageCollection('LANDSAT/LC09/C02/T1_L2'))
        )
      )
    )
  )
  .filterBounds(studyArea)
  .filterDate(start, end)
  .map(applyScaleFactors)
  .map(maskLandsat);

  var count = collection.size();

  var emptyNdvi = ee.Image(0)
    .rename('NDVI')
    .updateMask(ee.Image(0))
    .clip(studyArea)
    .set('year', year)
    .set('image_count', count);

  var emptyForest = ee.Image(0)
    .rename('forest')
    .updateMask(ee.Image(0))
    .clip(studyArea)
    .set('year', year)
    .set('image_count', count);

  var ndvi = ee.Image(
    ee.Algorithms.If(
      count.gt(0),
      (function() {
        var image = collection.median().clip(studyArea);

        return ee.Image(
          ee.Algorithms.If(
            year.lte(2012),
            image.normalizedDifference(['SR_B4', 'SR_B3']),
            image.normalizedDifference(['SR_B5', 'SR_B4'])
          )
        ).rename('NDVI')
         .set('year', year)
         .set('image_count', count);
      })(),
      emptyNdvi
    )
  );

  var forest = ee.Image(
    ee.Algorithms.If(
      count.gt(0),
      ndvi.gte(forestThreshold)
        .rename('forest')
        .set('year', year)
        .set('image_count', count),
      emptyForest
    )
  );

  return {
    ndvi: ndvi,
    forest: forest
  };
}

