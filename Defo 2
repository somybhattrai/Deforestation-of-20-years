// Use all years from 2005 to 2024
var years = ee.List.sequence(2005, 2024);

// Function to get yearly forest mask
var yearlyForest = ee.ImageCollection.fromImages(
  years.map(function(year) {
    year = ee.Number(year);

    var start = ee.Date.fromYMD(year, 5, 1);
    var end = ee.Date.fromYMD(year, 10, 31);

    // Choose the correct Landsat collection
    var collection = ee.ImageCollection(
      ee.Algorithms.If(
        year.lte(2011),
        // 2005-2011: Landsat 5
        ee.ImageCollection('LANDSAT/LT05/C02/T1_L2'),
        ee.Algorithms.If(
          year.eq(2012),
          // 2012: Landsat 7
          ee.ImageCollection('LANDSAT/LE07/C02/T1_L2'),
          ee.Algorithms.If(
            year.lte(2021),
            // 2013-2021: Landsat 8
            ee.ImageCollection('LANDSAT/LC08/C02/T1_L2'),
            // 2022-2024: Landsat 8 + 9
            ee.ImageCollection('LANDSAT/LC08/C02/T1_L2')
              .merge(ee.ImageCollection('LANDSAT/LC09/C02/T1_L2'))
          )
        )
      )
    )
    .filterBounds(studyArea)
    .filterDate(start, end)
    .map(applyScaleFactors)
    .map(maskLandsat);

    var count = collection.size();

    // Empty fallback image so the loop never crashes
    var emptyForest = ee.Image(0)
      .rename('forest')
      .updateMask(ee.Image(0))
      .clip(studyArea)
      .set('year', year)
      .set('image_count', count);

    // Only build NDVI if there are images
    var forestImage = ee.Image(
      ee.Algorithms.If(
        count.gt(0),
        (function() {
          var image = collection.median().clip(studyArea);

          var ndvi = ee.Image(
            ee.Algorithms.If(
              year.lte(2012),
              // Landsat 5 and 7
              image.normalizedDifference(['SR_B4', 'SR_B3']),
              // Landsat 8 and 9
              image.normalizedDifference(['SR_B5', 'SR_B4'])
            )
          ).rename('NDVI');

          var forest = ndvi.gte(forestThreshold).rename('forest');

          return forest
            .set('year', year)
            .set('image_count', count);
        })(),
        emptyForest
      )
    );

    return forestImage;
  })
);

print('Yearly forest collection:', yearlyForest);
print('Images available per year:', yearlyForest.aggregate_array('image_count'));

// Optional: test one year
Map.addLayer(
  ee.Image(yearlyForest.filter(ee.Filter.eq('year', 2012)).first()).selfMask(),
  {palette: ['green']},
  'Forest 2012'
);


// ==========================
// ANNUAL FOREST LOSS / GAIN / NET CHANGE
// SAFE VERSION
// ==========================

var pixelAreaKm2 = ee.Image.pixelArea().divide(1e6);

// Build annual results sequentially
var annualChange = ee.FeatureCollection(
  ee.List(years.slice(1)).iterate(function(year, acc) {
    year = ee.Number(year);
    var prevYear = year.subtract(1);

    var forestPrev = ee.Image(
      yearlyForest.filter(ee.Filter.eq('year', prevYear)).first()
    );

    var forestCurr = ee.Image(
      yearlyForest.filter(ee.Filter.eq('year', year)).first()
    );

    // Binary loss and gain
    var loss = forestPrev.eq(1).and(forestCurr.eq(0)).rename('loss');
    var gain = forestPrev.eq(0).and(forestCurr.eq(1)).rename('gain');

    // Put both into one image so only one reduceRegion is needed
    var areaImage = ee.Image.cat([
      loss.multiply(pixelAreaKm2).rename('loss_km2'),
      gain.multiply(pixelAreaKm2).rename('gain_km2')
    ]);

    var stats = areaImage.reduceRegion({
      reducer: ee.Reducer.sum(),
      geometry: studyArea,
      scale: 30,
      maxPixels: 1e13,
      bestEffort: true,
      tileScale: 8
    });

    var lossKm2 = ee.Number(stats.get('loss_km2', 0));
    var gainKm2 = ee.Number(stats.get('gain_km2', 0));
    var netKm2 = gainKm2.subtract(lossKm2);

    var feature = ee.Feature(null, {
      year: year,
      previous_year: prevYear,
      loss_km2: lossKm2,
      gain_km2: gainKm2,
      net_change_km2: netKm2
    });

    return ee.FeatureCollection(acc).merge(ee.FeatureCollection([feature]));
  }, ee.FeatureCollection([]))
);

print('Annual forest change table:', annualChange);

